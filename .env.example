# Frontend (optional — Gemini falls back to server-side key when API is running)
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Set to false to use in-memory mock data only (no SQLite persistence)
# VITE_USE_API=false

# Optional API base URL (default /api via Vite proxy in dev)
# VITE_API_URL=http://localhost:4000/api
