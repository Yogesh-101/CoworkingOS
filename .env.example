# Google Gemini API key (used by CoworkingOS Assist, Team Chat AI replies, etc.)
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# SereniBase production mode (see docker-compose.yml + BACKEND.md)
VITE_USE_SERENIBASE=true
# Leave empty when using Vite proxy (npm run dev); or set http://localhost:3001
VITE_API_URL=

# SereniBase / Docker (backend/.env for compose — copy from build/config/.env.example)
AUTH_JWT_SECRET=change-this-to-a-secure-random-string-min-32-chars-long
OWNER_EMAIL=admin@example.com
OWNER_PASSWORD=Admin@123

# Optional: override Vite dev server port (default 3000)
# PORT=3000
